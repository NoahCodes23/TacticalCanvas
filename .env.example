# Required. Create an OpenRouter key at https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-with-your-openrouter-key

# Optional. TacticalCanvas defaults to this model when the line is omitted.
OPENROUTER_MODEL=tencent/hy3:free

# Optional OpenRouter attribution headers.
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=TacticalCanvas
