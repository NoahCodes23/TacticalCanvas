# Coach LLM — OpenAI by default.
# Required. Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=replace-with-your-openai-key

# Optional. Defaults to gpt-4.1-mini when omitted.
# TC_COACH_MODEL=gpt-4.1-mini

# ---------------------------------------------------------------------------
# Provider-agnostic: point these at any OpenAI-compatible endpoint to switch
# providers without code changes (DeepSeek, Groq, Together, OpenRouter, Ollama…).
# TC_COACH_BASE_URL=https://api.openai.com
# TC_COACH_API_KEY=...        # overrides OPENAI_API_KEY if set
#
# Example — route through OpenRouter instead (keeps zero-data-retention):
# TC_COACH_BASE_URL=https://openrouter.ai/api
# OPENROUTER_API_KEY=replace-with-your-openrouter-key
# OPENROUTER_MODEL=tencent/hy3:free
# OPENROUTER_SITE_URL=http://localhost:8000
# OPENROUTER_APP_NAME=TacticalCanvas
